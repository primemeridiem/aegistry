# aegistry demo server configuration
# Run with: uv run uvicorn examples.server.main:app --port 8000 --env-file .env

# --- Google Sign-In ---------------------------------------------------------
# Create at https://console.cloud.google.com/apis/credentials
#   -> OAuth client ID, type "Web application"
#   -> Authorized redirect URI: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- LINE Login (optional) --------------------------------------------------
# Create a LINE Login channel at https://developers.line.biz/console/
#   -> Callback URL: http://localhost:3000/api/auth/line/callback
#   -> Apply for the email permission (OpenID Connect -> email)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# --- Optional overrides (defaults shown) -------------------------------------
# AEGISTRY_SECRET=demo-secret-do-not-use-in-production
# DATABASE_URL=sqlite+aiosqlite:///./demo.db
# WEB_BASE_URL=http://localhost:3000
